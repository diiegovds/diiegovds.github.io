<!DOCTYPE html> 
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Planilla Rosa — Pereyra 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --o: #FF6200;
  --o2: #FF8C38;
  --o3: #FFB270;
  --o-glow: rgba(255,98,0,0.35);
  --dark: #080400;
  --dark2: #0F0800;
  --mid: #1A1000;
  --white: #FFFCF7;
  --muted: rgba(255,252,247,0.45);
}

html { scroll-behavior: smooth; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--dark);
  color: var(--white);
  overflow-x: hidden;
  cursor: none;
}

/* CURSOR */
#cursor {
  position: fixed; z-index: 9999; pointer-events: none;
  width: 10px; height: 10px;
  background: var(--o);
  border-radius: 50%;
  transform: translate(-50%,-50%);
  transition: width 0.3s, height 0.3s, background 0.3s;
  mix-blend-mode: screen;
}
#cursor-ring {
  position: fixed; z-index: 9998; pointer-events: none;
  width: 36px; height: 36px;
  border: 1.5px solid rgba(255,98,0,0.5);
  border-radius: 50%;
  transform: translate(-50%,-50%);
  transition: all 0.12s ease-out;
}

/* NOISE OVERLAY */
body::before {
  content: '';
  position: fixed; inset: 0; z-index: 1; pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  opacity: 0.4;
}

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 1.5rem 4rem;
  display: flex; align-items: center; justify-content: space-between;
  transition: background 0.4s, backdrop-filter 0.4s, padding 0.4s;
}
nav.scrolled {
  background: rgba(8,4,0,0.85);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(255,98,0,0.12);
  padding: 1rem 4rem;
}
.nav-logo {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 1.1rem;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--o);
  display: flex; align-items: center; gap: 0.6rem;
}
.nav-logo span { color: var(--white); }
.nav-links { display: flex; gap: 2.5rem; }
.nav-links a {
  color: var(--muted); text-decoration: none;
  font-size: 0.78rem; font-weight: 500; letter-spacing: 1px; text-transform: uppercase;
  transition: color 0.2s;
  position: relative;
}
.nav-links a::after {
  content: ''; position: absolute; bottom: -4px; left: 0;
  width: 0; height: 1px; background: var(--o);
  transition: width 0.3s;
}
.nav-links a:hover { color: var(--white); }
.nav-links a:hover::after { width: 100%; }
.nav-cta {
  background: var(--o); color: var(--dark) !important;
  padding: 0.5rem 1.4rem; border-radius: 100px;
  font-weight: 700 !important; font-size: 0.78rem !important;
  transition: transform 0.2s, box-shadow 0.2s !important;
}
.nav-cta:hover { transform: scale(1.04); box-shadow: 0 0 24px var(--o-glow); }
.nav-cta::after { display: none !important; }

/* HERO */
#hero {
  min-height: 100vh;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  position: relative; overflow: hidden;
  text-align: center;
  padding: 8rem 2rem 4rem;
}

.hero-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  pointer-events: none;
}
.orb1 {
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(255,98,0,0.18) 0%, transparent 70%);
  top: -100px; left: 50%; transform: translateX(-50%);
  animation: orbFloat 8s ease-in-out infinite;
}
.orb2 {
  width: 300px; height: 300px;
  background: radial-gradient(circle, rgba(255,140,56,0.12) 0%, transparent 70%);
  bottom: 20%; right: 10%;
  animation: orbFloat 12s ease-in-out infinite reverse;
}
@keyframes orbFloat {
  0%,100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(-30px); }
}

.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 0.5rem;
  background: rgba(255,98,0,0.1); border: 1px solid rgba(255,98,0,0.25);
  padding: 0.35rem 1rem; border-radius: 100px;
  font-size: 0.72rem; font-weight: 500; letter-spacing: 2px; text-transform: uppercase;
  color: var(--o2); margin-bottom: 2rem;
  opacity: 0; animation: fadeUp 0.8s 0.3s forwards;
}
.eyebrow-dot {
  width: 6px; height: 6px; border-radius: 50%; background: var(--o);
  animation: dotPulse 2s infinite;
}
@keyframes dotPulse { 0%,100%{ opacity:1; } 50%{ opacity:0.3; } }

.hero-title {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: clamp(4.5rem, 12vw, 10rem);
  line-height: 0.92;
  letter-spacing: -2px;
  opacity: 0; animation: fadeUp 0.9s 0.5s forwards;
}
.hero-title .line2 {
  display: block;
  background: linear-gradient(90deg, var(--o) 0%, var(--o2) 50%, var(--o3) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-sub {
  max-width: 500px; margin: 2rem auto 0;
  font-size: 1.1rem; font-weight: 300; color: var(--muted); line-height: 1.7;
  opacity: 0; animation: fadeUp 0.9s 0.7s forwards;
}

.hero-cta-group {
  display: flex; align-items: center; gap: 1rem; margin-top: 3rem; justify-content: center;
  opacity: 0; animation: fadeUp 0.9s 0.9s forwards;
}
.btn-primary {
  background: var(--o); color: var(--dark);
  padding: 0.85rem 2.5rem; border-radius: 100px;
  font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.9rem;
  letter-spacing: 0.5px; text-decoration: none;
  transition: transform 0.2s, box-shadow 0.3s;
  box-shadow: 0 0 40px rgba(255,98,0,0.3);
}
.btn-primary:hover { transform: scale(1.04) translateY(-2px); box-shadow: 0 12px 50px rgba(255,98,0,0.45); }
.btn-ghost {
  color: var(--white); padding: 0.85rem 2rem; border-radius: 100px;
  font-size: 0.9rem; font-weight: 500; text-decoration: none;
  border: 1px solid rgba(255,255,255,0.15);
  transition: border-color 0.2s, color 0.2s;
}
.btn-ghost:hover { border-color: var(--o); color: var(--o); }

.hero-scroll {
  position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
  opacity: 0; animation: fadeUp 1s 1.4s forwards;
}
.scroll-line {
  width: 1px; height: 50px;
  background: linear-gradient(to bottom, var(--o), transparent);
  animation: scrollDrop 2s ease-in-out infinite;
}
@keyframes scrollDrop { 0%,100%{ transform: scaleY(1); opacity:1; } 50%{ transform: scaleY(0.6); opacity:0.5; } }
.scroll-text { font-size: 0.6rem; letter-spacing: 3px; text-transform: uppercase; color: var(--muted); }

@keyframes fadeUp {
  from { opacity:0; transform: translateY(30px); }
  to { opacity:1; transform: translateY(0); }
}

/* MARQUEE */
.marquee-section {
  overflow: hidden; padding: 1.5rem 0;
  border-top: 1px solid rgba(255,98,0,0.1);
  border-bottom: 1px solid rgba(255,98,0,0.1);
  background: rgba(255,98,0,0.04);
}
.marquee-track {
  display: flex; gap: 0; white-space: nowrap;
  animation: marquee 20s linear infinite;
}
.marquee-item {
  display: inline-flex; align-items: center; gap: 1.5rem;
  padding: 0 2rem;
  font-family: 'Syne', sans-serif; font-size: 0.75rem; font-weight: 600;
  letter-spacing: 2px; text-transform: uppercase; color: var(--muted);
}
.marquee-sep { color: var(--o); font-size: 1rem; }
@keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

/* SECTIONS SHARED */
.section { padding: 8rem 2rem; position: relative; }
.section-inner { max-width: 1100px; margin: 0 auto; }

.reveal { opacity: 0; transform: translateY(40px); transition: opacity 0.8s, transform 0.8s; }
.reveal.visible { opacity: 1; transform: translateY(0); }

/* LEMA */
#lema {
  text-align: center;
  padding: 10rem 2rem;
}
.lema-word {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: clamp(2.5rem, 6vw, 5.5rem);
  line-height: 1.1;
  opacity: 0; transform: translateY(20px);
  transition: opacity 0.6s, transform 0.6s;
  display: block;
}
.lema-word.visible { opacity: 1; transform: translateY(0); }
.lema-word.accent { color: var(--o); }
.lema-word.small { font-size: clamp(1rem, 2.5vw, 1.5rem); color: var(--muted); font-weight: 300; font-family: 'DM Sans', sans-serif; margin-top: 1.5rem; }

/* PROPUESTAS */
#propuestas { background: var(--dark2); }

.proposals-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5px;
  background: rgba(255,98,0,0.1);
  border: 1.5px solid rgba(255,98,0,0.1);
  border-radius: 20px;
  overflow: hidden;
  margin-top: 4rem;
}
.proposal-card {
  background: var(--dark2);
  padding: 2.5rem 2rem;
  position: relative; overflow: hidden;
  transition: background 0.4s;
  cursor: default;
}
.proposal-card::before {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(255,98,0,0.06) 0%, transparent 60%);
  opacity: 0; transition: opacity 0.4s;
}
.proposal-card:hover { background: rgba(255,98,0,0.05); }
.proposal-card:hover::before { opacity: 1; }
.proposal-num {
  font-family: 'Syne', sans-serif; font-weight: 800;
  font-size: 0.65rem; letter-spacing: 3px; text-transform: uppercase;
  color: rgba(255,98,0,0.4); margin-bottom: 1.5rem;
  display: flex; align-items: center; gap: 0.5rem;
}
.proposal-num::after { content: ''; flex:1; height:1px; background: rgba(255,98,0,0.15); }
.proposal-icon { font-size: 2rem; margin-bottom: 1rem; display: block; }
.proposal-title {
  font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.1rem;
  margin-bottom: 0.8rem; line-height: 1.3;
}
.proposal-body {
  font-size: 0.83rem; color: var(--muted); line-height: 1.7;
}
.proposal-tag {
  display: inline-block; margin-top: 1.2rem;
  background: rgba(255,98,0,0.1); border: 1px solid rgba(255,98,0,0.2);
  color: var(--o2); font-size: 0.65rem; font-weight: 600;
  padding: 0.25rem 0.7rem; border-radius: 100px; letter-spacing: 0.8px;
  text-transform: uppercase;
}

.section-label {
  font-size: 0.68rem; font-weight: 600; letter-spacing: 3px; text-transform: uppercase;
  color: var(--o); margin-bottom: 1rem;
  display: flex; align-items: center; gap: 0.8rem;
}
.section-label::before { content: ''; width: 24px; height: 1px; background: var(--o); }
.section-title {
  font-family: 'Syne', sans-serif; font-weight: 800;
  font-size: clamp(2rem, 4vw, 3.5rem);
  line-height: 1.05; letter-spacing: -1px;
}

/* EQUIPO */
#equipo { overflow: hidden; }

.team-intro {
  display: grid; grid-template-columns: 1fr 1fr; gap: 6rem;
  align-items: center; margin-bottom: 6rem;
}
.team-intro-stat { text-align: right; }
.stat-number {
  font-family: 'Syne', sans-serif; font-weight: 800;
  font-size: 7rem; line-height: 1;
  background: linear-gradient(135deg, var(--o), var(--o3));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}
.stat-label { font-size: 0.85rem; color: var(--muted); margin-top: 0.5rem; }

.team-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 1rem;
}
.member-card {
  position: relative; overflow: hidden;
  border-radius: 16px;
  aspect-ratio: 3/4;
  background: var(--mid);
  cursor: pointer;
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.member-card:hover { transform: translateY(-8px) scale(1.02); }
.member-photo {
  width: 100%; height: 100%;
  object-fit: cover; object-position: top center;
  display: block;
  filter: grayscale(15%) contrast(1.05);
  transition: filter 0.4s, transform 0.4s;
}
.member-card:hover .member-photo { filter: grayscale(0%) contrast(1.1); transform: scale(1.05); }
.member-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(8,4,0,0.95) 0%, rgba(8,4,0,0.3) 50%, transparent 100%);
  display: flex; flex-direction: column; justify-content: flex-end;
  padding: 1rem 0.8rem;
  opacity: 0; transition: opacity 0.3s;
}
.member-card:hover .member-overlay { opacity: 1; }
.member-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.72rem; line-height: 1.2; }
.member-role { font-size: 0.6rem; color: var(--o2); margin-top: 0.2rem; letter-spacing: 0.5px; }
.member-badge {
  position: absolute; top: 0.6rem; left: 0.6rem;
  background: var(--o); color: var(--dark);
  font-family: 'Syne', sans-serif; font-weight: 800;
  font-size: 0.55rem; padding: 0.2rem 0.5rem; border-radius: 100px;
  text-transform: uppercase; letter-spacing: 0.8px;
}
.member-card.pres .member-badge { background: var(--white); }

.member-photo-placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-size: 3rem;
  background: linear-gradient(135deg, var(--mid) 0%, rgba(255,98,0,0.08) 100%);
}

/* CAMPAIGN TIMELINE — new phase-based layout */
#activaciones { background: linear-gradient(180deg, var(--dark) 0%, var(--dark2) 100%); }

.phases-grid {
  margin-top: 4rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5px;
  background: rgba(255,98,0,0.1);
  border: 1.5px solid rgba(255,98,0,0.1);
  border-radius: 20px;
  overflow: hidden;
}
.phase-card {
  background: var(--dark2);
  padding: 2.2rem 2rem;
  position: relative; overflow: hidden;
  transition: background 0.4s;
}
.phase-card::before {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(255,98,0,0.05) 0%, transparent 60%);
  opacity: 0; transition: opacity 0.4s;
}
.phase-card:hover { background: rgba(255,98,0,0.04); }
.phase-card:hover::before { opacity: 1; }
.phase-card.full-width { grid-column: 1 / -1; }

.phase-header {
  display: flex; align-items: flex-start; gap: 1.2rem; margin-bottom: 1.2rem;
}
.phase-num-badge {
  flex-shrink: 0;
  width: 36px; height: 36px;
  background: rgba(255,98,0,0.12);
  border: 1px solid rgba(255,98,0,0.25);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Syne', sans-serif; font-weight: 800;
  font-size: 0.7rem; color: var(--o);
}
.phase-meta { flex: 1; }
.phase-dates {
  font-size: 0.62rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
  color: var(--o); margin-bottom: 0.3rem;
}
.phase-title {
  font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.05rem; line-height: 1.25;
}
.phase-body {
  font-size: 0.82rem; color: var(--muted); line-height: 1.7;
  margin-bottom: 1rem;
}
.phase-items {
  list-style: none; display: flex; flex-direction: column; gap: 0.35rem;
}
.phase-items li {
  display: flex; align-items: baseline; gap: 0.5rem;
  font-size: 0.8rem; color: var(--muted); line-height: 1.5;
}
.phase-items li::before {
  content: '→'; color: var(--o); font-size: 0.7rem; flex-shrink: 0;
}
.phase-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 1rem; }
.chip {
  background: rgba(255,98,0,0.08); border: 1px solid rgba(255,98,0,0.2);
  color: var(--o2); font-size: 0.62rem; font-weight: 600; letter-spacing: 0.5px;
  padding: 0.2rem 0.6rem; border-radius: 100px; text-transform: uppercase;
}
.phase-card.highlight {
  background: linear-gradient(135deg, rgba(255,98,0,0.1) 0%, rgba(255,98,0,0.03) 100%);
  border-left: 2px solid var(--o);
}

/* VOTO CTA */
#voto {
  text-align: center; padding: 12rem 2rem;
  position: relative; overflow: hidden;
}
#voto::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(255,98,0,0.12) 0%, transparent 70%);
}
.voto-date {
  display: inline-block;
  font-family: 'Syne', sans-serif; font-weight: 700;
  font-size: clamp(4rem, 14vw, 12rem);
  line-height: 1; letter-spacing: -3px;
  background: linear-gradient(90deg, rgba(255,98,0,0.2) 0%, var(--o) 40%, var(--o3) 70%, rgba(255,98,0,0.2) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: shimmer 3s ease-in-out infinite;
  background-size: 200% 100%;
}
@keyframes shimmer {
  0% { background-position: 200% center; }
  100% { background-position: -200% center; }
}
.voto-label { font-size: 0.7rem; letter-spacing: 4px; text-transform: uppercase; color: var(--muted); margin-bottom: 1.5rem; }
.voto-text { font-size: 1.2rem; color: var(--muted); font-weight: 300; margin-top: 1.5rem; max-width: 400px; margin-left: auto; margin-right: auto; }
.voto-cta { margin-top: 3rem; }

/* FOOTER */
footer {
  border-top: 1px solid rgba(255,98,0,0.1);
  padding: 3rem 4rem;
  display: flex; align-items: center; justify-content: space-between;
  font-size: 0.75rem; color: var(--muted);
}
.footer-logo { font-family: 'Syne', sans-serif; font-weight: 800; color: var(--o); letter-spacing: 2px; font-size: 1rem; }
.footer-links { display: flex; gap: 2rem; }
.footer-links a { color: var(--muted); text-decoration: none; transition: color 0.2s; }
.footer-links a:hover { color: var(--o); }

/* RESPONSIVE */
@media(max-width:900px) {
  nav { padding: 1.2rem 1.5rem; }
  nav.scrolled { padding: 0.8rem 1.5rem; }
  .nav-links { display: none; }
  .proposals-grid { grid-template-columns: 1fr; }
  .phases-grid { grid-template-columns: 1fr; }
  .phase-card.full-width { grid-column: 1; }
  .team-grid { grid-template-columns: repeat(4, 1fr); }
  .team-intro { grid-template-columns: 1fr; gap: 2rem; }
  .team-intro-stat { text-align: left; }
  footer { flex-direction: column; gap: 1rem; text-align: center; padding: 2rem; }
  .footer-links { flex-wrap: wrap; justify-content: center; }
}
@media(max-width:600px) {
  .team-grid { grid-template-columns: repeat(3, 1fr); }
}
</style>
</head>
<body>

<div id="cursor"></div>
<div id="cursor-ring"></div>

<!-- NAV -->
<nav id="mainNav">
  <div class="nav-logo">🍊 <span>Planilla</span> Naranja</div>
  <div class="nav-links">
    <a href="#propuestas">Propuestas</a>
    <a href="#equipo">Equipo</a>
    <a href="#activaciones">Campaña</a>
    <a href="https://www.instagram.com/planilla_naranja_lag/" target="_blank" class="nav-cta">Síguenos en Instagram</a>
  </div>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hero-orb orb1"></div>
  <div class="hero-orb orb2"></div>

  <div class="hero-eyebrow">
    <span class="eyebrow-dot"></span>
    FETECMI Torreón · Gestión AGO26–MAY27
  </div>

  <h1 class="hero-title">
    Tu voz,<br>
    <span class="line2">nuestra misión.</span>
  </h1>

  <p class="hero-sub">
    Somos la Planilla Naranja. Compromiso, Acción y Resultados para la comunidad Tecmilenio Torreón.
  </p>

  <div class="hero-cta-group">
    <a href="#propuestas" class="btn-primary">Ver propuestas</a>
    <a href="#equipo" class="btn-ghost">Conocer al equipo →</a>
  </div>

  <div class="hero-scroll">
    <span class="scroll-text">Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- MARQUEE -->
<div class="marquee-section">
